## Visual Studio / .NET Core .gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
bin/
obj/

# Visual Studio workspace
.vs/

# Rider
.idea/

# ReSharper
_ReSharper*/
*.DotSettings.user

# NuGet
packages/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
.nuget/

# VS Code
.vscode/

# Test results
TestResults/
*.trx
*.coverage

# Publish output
publish/
*.Publish.xml

# Logs
*.log

# Local DB and database files
*.mdf
*.ldf
*.sqlite
*.db

# OS generated files
Thumbs.db
.DS_Store

# Node
node_modules/

# Azure Functions local settings
.local.settings.json

# User secrets (optional, uncomment if you use secrets file locally)
# Secrets files are often environment-specific and should not be committed.
# secrets.json

# Debugger files
*.vshost.*

# Files generated by Visual Studio
*.vsp
*.vsix

# Temporary files
*.tmp
*.temp

# JetBrains Rider caches
/.idea/

# Dotnet watch
.dotnet-watch/

# Coverage tooling output
.coverage
.coveragexml

# MSBuild binary logs
*.binlog
